<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AssemblyName>$(AssemblyName)</AssemblyName>

		<PackAsTool>True</PackAsTool>
		<ToolCommandName>hfget</ToolCommandName>
		<PackageId>crwsolutions.hfget</PackageId>
		<Version>1.0.0</Version>
		<Title>Huggingface Get Tool</Title>
		<Description>A CLI tool to get a huggingface model</Description>
		<Authors>Colin Wilmans</Authors>
		<Company>crwsolutions</Company>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>cli;tool;hf;api;huggingface;model;download</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Spectre.Console.Cli" Version="0.55.0" />
	</ItemGroup>

</Project>
